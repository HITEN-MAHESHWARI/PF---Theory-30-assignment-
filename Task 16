#include <stdio.h>

int main() {
    int a[6];
    int i;
    
    
    printf("Enter the 6 integer: ");
    for(i = 0; i < 6; i++){
        scanf("%d", &a[i]);
    }
    printf("Odd index elements are: ");
    for(i = 0; i < 6; i++){
        if(i % 2 == 1){
        printf("%d ", a[i]);
        }
    }
    
    return 0;
}
