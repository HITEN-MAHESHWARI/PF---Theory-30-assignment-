#include<stdio.h>
int main(){
    int a[5];
    int i;
    int j;
    int temp = 0;
    
    printf("Enter 5 integer: ");
    for(i = 0; i < 5; i++){
        scanf("%d", &a[i]);
    }
    for(i = 0; i < 6; i++){
        for(j = i + 1; j < 6; j++){
            if(a[i] > a[j]){
               temp = a[j];
               a[j]  = a[i];
               a[i] = temp;
            }
        }
        
    }
    for(i = 4; i >= 0; i--)
        printf("%d ", a[i]);
    return 0;
}
