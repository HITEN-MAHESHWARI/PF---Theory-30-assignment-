#include <stdio.h>

int main() {
    int a[6];
    int i;
    int sum = 0;
    
    printf("Enter the 6 integer: ");
    for(i = 0; i < 6; i++){
        scanf("%d", &a[i]);
    }
    for(i = 0; i < 6; i++){
        sum = sum + a[i];
    }
    
        printf("Sum of all element is %d ", sum);

    return 0;
}
