#include <stdio.h>

int main() {
    int a[6];
    int i;
    int temp;
    int j;
   
    printf("Ente 6 integer: ");
    for(i = 0; i < 6; i++){
        scanf("%d", &a[i]);
    }
    for(i = 0; i < 5; i++){
        for(j = i + 1; j < 6; j++){
            if(a[i] > a[j]){
                temp = a[i];
                a[i] = a[j];
                a[j] = temp;
            }
        }
   
    }
    printf("Smallest number is %d", a[0]);

    return 0;
}
