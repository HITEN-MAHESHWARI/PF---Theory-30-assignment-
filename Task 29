#include <stdio.h>

int main()
{
    int a[5]; 
    int i;
    int max;
    int min;
    int diff;

    printf("Enter 5 integers:\n");
    for(i = 0; i < 5; i++){
        scanf("%d", &a[i]);
        }
    max = a[0];
    min = a[0];

    for(i = 1; i < 5; i++)
    {
        if(a[i] > max)
            max = a[i];

        if(a[i] < min)
            min = a[i];
    }
    diff = max - min;
    printf("Difference = %d", diff);

    return 0;
}
