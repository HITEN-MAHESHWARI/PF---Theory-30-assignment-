#include <stdio.h>

int main() {
    int a[6];
    int i;
    int j;
    
    printf("Enter 6 integer: ");
    for(i = 0; i < 6; i++){
        scanf("%d", &a[i]);
    }
    for(i = 0; i < 6; i++){
        for(j = i + 1; j < 6; j++)
        if(a[i] == a[j]){
            printf("duplicate %d, ", a[j]); break;
        }
    }
    
    return 0;
}
