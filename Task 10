#include <stdio.h>

int main() {
    int a[5];
    int rem;
    int i;
    int reverse = 0;
    int num;
   
    printf("Enter 5 integer: ");
   
    for(i = 0; i < 5; i++){
        scanf("%d", &a[i]);
    }
    for(i = 0; i < 5; i++){
       num = a[i];
       reverse =0;
   
    while(num != 0){
        rem = num % 10;
        reverse = reverse * 10 + rem;
        num = num / 10;
    }
    if(reverse == a[i]){
        printf("Palindrome\n");
    }
    else{
        printf("Not polindrome\n");
    }
    }
   

    return 0;
}
