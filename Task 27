#include <stdio.h>

int main() {
    int a[5];
    int i; 
    int start;

    printf("Enter 5 integers:\n");
    for (i = 0; i < 5; i++)
        scanf("%d", &a[i]);

    start = a[0];

    for (i = 0; i  < 4; i++)
        a[i] = a[i + 1];
    a[4] = start;
    printf("Output: ");
    for (i = 0; i < 5; i++)
        printf("%d ", a[i]);

    return 0;
}
