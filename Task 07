#include <stdio.h>
int main() {
    int a[5];
    int i,freq[100]={0};
    printf("Enter 5 integers: ");
    for(i = 0; i < 5; i++){
        scanf("%d", &a[i]);
    }
    printf("Remaining Elements: ");
    for(i=0;i<5;i++)
    {
        if(freq[a[i]]==0)
        printf("%d ",a[i]);
            freq[a[i]]++;
    }
}
