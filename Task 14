#include <stdio.h>

int main() {
    int a[6];
    int i;
    int sum = 0;
    double avg;
    
    printf("Enter the 6 integer: ");
    for(i = 0; i < 6; i++){
        scanf("%d", &a[i]);
    }
    for(i = 0; i < 6; i++){
        sum = sum + a[i];
    }
    avg = sum / 6.0;
    printf("Aevrage of all element is: %.2lf", avg);
    
    return 0;
}
